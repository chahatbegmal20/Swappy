# Database
DATABASE_URL=postgresql+asyncpg://swappy:swappy@localhost:5432/swappy
DATABASE_URL_SYNC=postgresql://swappy:swappy@localhost:5432/swappy

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=swappy-uploads

# Auth
JWT_SECRET=change-me-in-production-use-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ML
MODEL_PATH=./data/models
DEVICE=cpu

# App
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
